{
  "name": "wechat-game1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "data": "tsx scripts/build-data.ts",
    "data:watch": "tsx scripts/build-data.ts --watch",
    "dev": "npm run data && vite",
    "build": "npm run data && vite build",
    "preview": "vite preview",
